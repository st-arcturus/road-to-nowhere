//- vim:ts=4:sw=4:
extends layout

block head
	if thread.is_hidden && !user.is_moderator
		title Removed thread.
	else
		title= thread.subject

block body
	if thread.is_hidden && !user.is_moderator
		h1 ...
		p.box This thread has been removed by a moderator.

	else

		h1= thread.subject

		if thread.is_hidden
			p.box This thread has been removed by a moderator.
		else if thread.is_locked
			p.box This thread has been locked.

		each row in posts
			if row.is_hidden && !user.is_moderator
				p.box(id=row.post_id) This post has been removed by a moderator.
			else
				div(id=row.post_id, class=(user.is_moderator && row.is_hidden) ? "post removed" : "post")
					.head
						.from: b: a.black(href="/user/"+row.author_name)= row.author_name
						if row.in_reply_to
							a.black(href="#"+row.in_reply_to) (in reply to)
						a.black(href="#"+row.post_id)= human_date(row.ctime)
							if row.edited
								|
								| (edited #{human_date(row.mtime)})
					.body!= row.body
				.edit
					if user.is_moderator
						if !row.is_hidden
							a.mod(href="/forum/hide-post/"+row.post_id, onclick="return confirm('Are you sure you want to hide this post?')") HIDE
					if user.is_admin
						a.mod(href="/forum/delete-post/"+row.post_id, onclick="return confirm('Are you sure you want to delete this post?')") DELETE
					if !thread.is_locked && !user.is_muted
						if row.author_id === user.user_id
							a(href="/forum/edit/"+row.post_id) Edit
						a(href="/forum/reply/"+row.post_id) Reply

		if !thread.is_locked && posts.length > 0
			if !user.is_muted
				p
					a(href="/forum/reply/"+posts[0].post_id) Reply

	if user.is_moderator
		fieldset.mod
			legend MODERATOR
			if !thread.is_locked
				div: a.mod(href="/forum/lock-thread/"+thread.thread_id) LOCK THREAD
			if !thread.is_hidden
				div: a.mod(href="/forum/hide-thread/"+thread.thread_id) HIDE THREAD

	if user.is_admin
		fieldset.mod
			legend ADMIN
			div: a.mod(href="/forum/delete-thread/"+thread.thread_id) DELETE THREAD
